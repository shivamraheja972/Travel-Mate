# TravelMate (Supabase-only) environment template
# Copy to `.env` in the repo root for docker-compose usage.

# Required: Supabase public client credentials
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: Public Stripe key for client-side Stripe widgets
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_your_public_key
REACT_APP_TRAVELPAYOUTS_TOKEN=your_travelpayouts_token
